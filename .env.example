# Copy this file to ".env" before running the app:  cp .env.example .env
#
# Local SQLite database for development. Prisma resolves this path relative to
# prisma/schema.prisma, so the database file lives at prisma/dev.db.
# No secrets belong in this file.
DATABASE_URL="file:./dev.db"

# Auth.js / NextAuth session secret (encrypts the JWT session cookie). Generate a
# strong random value in your real .env (never commit it), e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""
