# Copy this file to ".env" before running the app:  cp .env.example .env
# No secrets belong in this file — put real values only in .env (git-ignored).
#
# Postgres (Supabase). Two URLs:
#   DATABASE_URL = transaction pooler (:6543, add ?pgbouncer=true) — app runtime.
#   DIRECT_URL   = session pooler (:5432) — Prisma migrations.
# Percent-encode special characters in the password (e.g. "!" -> %21).
DATABASE_URL="postgresql://USER:PASSWORD@HOST.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.pooler.supabase.com:5432/postgres"

# Auth.js / NextAuth session secret (encrypts the JWT session cookie). Generate a
# strong random value in your real .env (never commit it), e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# App-wide timezone for calendar-day logic (check-ins, streaks). IANA name.
APP_TIMEZONE="America/Chicago"
