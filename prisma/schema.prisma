// Elite24MVP — Prisma schema
//
// Data layer for the team-private basketball development app (see CLAUDE.md).
// SQLite is an MVP/testing choice; keep the data layer swappable for a hosted
// database later (CLAUDE.md section 6).
//
// Phase 1 introduces Team, User, and PlayerProfile; Phase 3 adds JournalEntry
// and PointsLedger; Phase 4 adds Quest and QuestLog; Phase 5 adds Notification
// and NotificationRead.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  COACH
  PLAYER
}

// A team is the private space a coach runs for their players.
//
// `parentId` is a nullable self-relation: a team can later belong to a larger
// grouping (conference / region) so leaderboards can be scoped to any level
// (CLAUDE.md section 3.5). It is intentionally unused in the UI for now — the
// app shows a single-team view — but the model must never hard-code "one team".
model Team {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())

  // Future branding (logo, accent color). Optional; no UI yet.
  logoUrl     String?
  accentColor String?

  // Future grouping hook (conference/region). Unused in the current UI.
  parentId Int?
  parent   Team?  @relation("TeamHierarchy", fields: [parentId], references: [id])
  children Team[] @relation("TeamHierarchy")

  users         User[]
  notifications Notification[]
  teamMessages  TeamMessage[]
}

// A user is either a COACH (team admin) or a PLAYER. Both belong to one team.
// No password field yet: Phase 1 uses the dev user switcher for local testing,
// and real auth will be added with a vetted library in a later hardening phase
// (CLAUDE.md section 6).
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  role      Role
  createdAt DateTime @default(now())

  teamId Int
  team   Team @relation(fields: [teamId], references: [id])

  // Players have a profile; coaches do not.
  profile PlayerProfile?

  // A player's daily check-ins, points history, and quest completions.
  journalEntries JournalEntry[]
  pointsLedger   PointsLedger[]
  questLogs      QuestLog[]

  // Notifications a coach has authored, and a player's read-confirmations.
  authoredNotifications Notification[]     @relation("NotificationAuthor")
  notificationReads     NotificationRead[]

  // Team message board posts this user has authored, and reactions they've made.
  teamMessages     TeamMessage[]
  messageReactions MessageReaction[]
  messageComments  MessageComment[]
}

// Player-only data: the required Dream plus structured "Your Brand" stats.
// Kept on a separate 1:1 model so the User model stays clean for both roles
// and we only collect what the loop needs (CLAUDE.md section 3.4).
model PlayerProfile {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // The Dream is required at onboarding and is the heart of the loop (section 2).
  dream String

  // Structured basketball stats (all optional; entered by the player).
  heightInches    Int?
  position        String?
  jerseyNumber    Int?
  pointsPerGame   Float?
  reboundsPerGame Float?
  assistsPerGame  Float?

  favoritePlayer String?
  favoriteTeam   String?

  // A single highlight reel — a PASTED LINK only (no upload/hosting, section 5).
  highlightUrl String?

  // Convenience cache of the player's total points. The PointsLedger is the
  // source of truth; this is kept in sync in the same transaction as each
  // ledger write so a future leaderboard can read a single number quickly.
  points Int @default(0)

  // Set when the player completes first-time onboarding (CLAUDE.md section 2).
  // Null = not yet onboarded. In the seed, a not-yet-onboarded player has no
  // PlayerProfile row at all; this timestamp marks completion explicitly.
  onboardedAt DateTime?

  createdAt DateTime @default(now())
}

// One row per daily check-in: the player's typed reflection for a calendar day.
// One per player per day (see @@unique). Typed text only — no photo upload and
// no AI grading (CLAUDE.md section 3.3).
model JournalEntry {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reflection String
  day        String   // calendar day "YYYY-MM-DD" (server-local time)
  createdAt  DateTime @default(now())

  @@unique([userId, day])
  @@index([userId])
}

// Where a points-earning event came from. New sources (quests, coach awards)
// are added here as the app grows, so they can be told apart.
enum PointsSource {
  DAILY_CHECK_IN
  QUEST
}

// The points ledger is the source of truth for a player's points: one row per
// earning event. A player's total = the sum of their rows. PlayerProfile.points
// is a convenience cache kept in sync in the same transaction.
model PointsLedger {
  id        Int          @id @default(autoincrement())
  userId    Int
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  reason    String
  source    PointsSource
  createdAt DateTime     @default(now())

  // The quest completion that awarded this row (null for non-quest sources like
  // the daily check-in). 1:1 — set by logQuest, used by undoQuest. onDelete:
  // Cascade so undeleting a completion (deleting its QuestLog) removes this row.
  questLogId Int?      @unique
  questLog   QuestLog? @relation(fields: [questLogId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Daily quests are shared, global definitions for the MVP (not team-specific).
// PLACEHOLDER content lives in the seed; Gary replaces it later. Kept clean so a
// nullable teamId could be added later for team-specific quests (CLAUDE.md 3.5).
model Quest {
  id          Int        @id @default(autoincrement())
  title       String
  description String
  points      Int
  active      Boolean    @default(true)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())

  logs QuestLog[]
}

// Whether a quest completion has been awarded. Defaults to APPROVED so points
// are earned immediately (no approval UI in this phase). PENDING leaves room for
// a future coach-approval flow without a schema change.
enum QuestStatus {
  PENDING
  APPROVED
}

// One row per player completing a quest on a calendar day. One per player per
// quest per day (see @@unique), mirroring the daily check-in pattern.
model QuestLog {
  id        Int         @id @default(autoincrement())
  userId    Int
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  questId   Int
  quest     Quest       @relation(fields: [questId], references: [id], onDelete: Cascade)
  day       String      // calendar day "YYYY-MM-DD" (server-local time)
  status    QuestStatus @default(APPROVED)
  createdAt DateTime    @default(now())

  // The points-ledger row this completion created (set by logQuest). Cascade-
  // deleted with the log on undo.
  pointsLedger PointsLedger?

  @@unique([userId, questId, day])
  @@index([userId])
  @@index([questId])
}

// A note a coach posts to their own team. Belongs to exactly one team
// (team-scoped, CLAUDE.md section 3.2). In-app only — no push or email.
model Notification {
  id        Int      @id @default(autoincrement())
  teamId    Int
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  authorId  Int
  author    User     @relation("NotificationAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  title     String
  body      String
  // Urgent "TIME OUT" takeover that covers a player's app until acknowledged
  // (acknowledgement reuses NotificationRead). Default = a normal notification.
  isTimeout Boolean  @default(false)
  createdAt DateTime @default(now())

  reads NotificationRead[]

  @@index([teamId])
}

// A record that a specific player has confirmed reading a specific
// notification. One per player per notification (see @@unique).
model NotificationRead {
  id             Int          @id @default(autoincrement())
  notificationId Int
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  userId         Int
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt         DateTime     @default(now())

  @@unique([notificationId, userId])
  @@index([userId])
}

// A text post on a team's message board (CLAUDE.md §2/§3). Belongs to exactly
// one team (team-scoped, §3.2). Text only — no images/attachments. Soft-deleted
// via deletedAt for coach moderation / author removal (kept rather than hard-
// deleted so removals are auditable for a kids' space, §3.1).
// `type` is REGULAR for everyone's normal messages; the colored special types
// (Discussion/Challenge/Spotlight) are coach-only, enforced in the post action.
model TeamMessage {
  id        Int         @id @default(autoincrement())
  teamId    Int
  team      Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  authorId  Int
  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  type      MessageType @default(REGULAR)
  // References a curated GIF id from lib/gifs.ts (NOT a DB relation — the registry
  // lives in code). Validated against the registry server-side on every post, so a
  // message can never point at an arbitrary/external image. Null = no GIF.
  gifId     String?
  createdAt DateTime    @default(now())
  deletedAt DateTime?

  reactions MessageReaction[]
  comments  MessageComment[]

  @@index([teamId])
}

enum MessageType {
  REGULAR
  DISCUSSION // blue  — "Discussion of the Day" (coach only)
  CHALLENGE  // green — "Challenge of the Week" (coach only)
  SPOTLIGHT  // red   — "Coach's Spotlight" (coach only)
}

enum ReactionType {
  THUMBS_UP
  HEART
}

// A 👍 / ❤️ reaction by a team member on a board message. One of each type per
// user per message (see @@unique). Team-scoped (verified in the action).
model MessageReaction {
  id           Int          @id @default(autoincrement())
  messageId    Int
  message      TeamMessage  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId       Int
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactionType ReactionType
  createdAt    DateTime     @default(now())

  @@unique([messageId, userId, reactionType])
  @@index([messageId])
}

// A flat, one-level text comment on a board message. References a message (never
// another comment). Soft-deleted via deletedAt for coach / author moderation.
model MessageComment {
  id        Int         @id @default(autoincrement())
  messageId Int
  message   TeamMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  authorId  Int
  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime    @default(now())
  deletedAt DateTime?

  @@index([messageId])
}
